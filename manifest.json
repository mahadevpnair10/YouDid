{
  "manifest_version": 3,
  "name": "YouDid",
  "description": "History Analyser and Apriori algo runner to see a users browsing pattern.",
  "version": "1.0.0",

  "action": {
    "default_title": "Open Extension",
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "history",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}